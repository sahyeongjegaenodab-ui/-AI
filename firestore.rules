rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    
    // 1. Global Default Deny Safety Net
    match /{document=**} {
      allow read, write: if false;
    }

    function isValidId(id) {
      return id is string && id.size() <= 128;
    }

    // --- ENTITY 1: User Profile Validation ---
    function isValidUser(data) {
      return data.nickname is string 
        && data.nickname.size() >= 2 
        && data.nickname.size() <= 20
        && data.password is string
        && data.password.size() >= 4
        && data.createdAt == request.time;
    }

    // --- ENTITY 2: Chat Message Validation ---
    function isValidChatMessage(data) {
      return data.senderUid is string
        && data.senderNickname is string
        && data.senderNickname.size() >= 2
        && data.senderNickname.size() <= 20
        && data.content is string
        && data.content.size() >= 1
        && data.content.size() <= 200
        && data.createdAt == request.time;
    }

    // --- MATCH BLOCKS ---
    
    // User collection rules - direct lookup and creation open for security verification
    match /users/{userId} {
      allow get: if true;
      allow list: if false; // Block user listings to prevent harvesting accounts
      allow create: if isValidId(userId)
                    && request.resource.data.keys().hasAll(['nickname', 'password', 'createdAt'])
                    && request.resource.data.keys().size() == 3
                    && isValidUser(request.resource.data);
      allow update: if false; // Profiles are single-creation for simplicity and security
      allow delete: if false;
    }

    // Global chat rules
    match /global_chats/{messageId} {
      allow list: if true;
      allow get: if true;
      allow create: if isValidId(messageId)
                    && request.resource.data.keys().hasAll(['senderUid', 'senderNickname', 'content', 'createdAt'])
                    && request.resource.data.keys().size() == 4
                    && isValidChatMessage(request.resource.data);
      allow update: if false;
      allow delete: if false;
    }
  }
}
